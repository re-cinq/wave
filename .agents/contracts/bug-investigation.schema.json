{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bug Investigation",
  "type": "object",
  "required": [
    "root_cause",
    "affected_files",
    "fix_approach",
    "timestamp"
  ],
  "properties": {
    "root_cause": {
      "type": "object",
      "required": ["file", "function", "condition", "explanation"],
      "properties": {
        "file": {
          "type": "string",
          "description": "File containing the root cause"
        },
        "function": {
          "type": "string",
          "description": "Function or method containing the bug"
        },
        "line_range": {
          "type": "string",
          "description": "Line range of the problematic code"
        },
        "condition": {
          "type": "string",
          "description": "Condition that triggers the bug"
        },
        "explanation": {
          "type": "string",
          "description": "Detailed explanation of why this is the root cause"
        }
      },
      "description": "Structured root cause analysis"
    },
    "affected_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of affected file paths"
    },
    "execution_path": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Call chain or execution path leading to the bug"
    },
    "recent_commits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of relevant commit hashes"
    },
    "blast_radius": {
      "type": "object",
      "properties": {
        "similar_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Other code locations with similar patterns"
        },
        "callers_affected": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Callers or consumers affected by this bug"
        },
        "existing_test_gaps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Test coverage gaps related to this bug"
        }
      },
      "description": "Assessment of what else could be affected"
    },
    "fix_approach": {
      "type": "string",
      "description": "Recommended approach to fix the issue"
    },
    "fix_strategy": {
      "type": "object",
      "properties": {
        "approach": {
          "type": "string",
          "description": "High-level fix strategy"
        },
        "steps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered steps to implement the fix"
        },
        "risks": {
          "type": "string",
          "description": "Risks associated with the fix"
        }
      },
      "description": "Structured fix strategy"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when investigation completed"
    }
  },
  "additionalProperties": true
}
