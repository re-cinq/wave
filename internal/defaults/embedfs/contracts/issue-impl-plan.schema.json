{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Issue Implementation Plan",
  "description": "Planning artifact produced by impl-issue / impl-issue-core before implementation. Flexible shape — supports both task-decomposed (id/title/description) and file-list shapes.",
  "type": "object",
  "required": ["issue_number"],
  "anyOf": [
    {"required": ["branch_name"]},
    {"required": ["branch"]}
  ],
  "properties": {
    "issue_number": { "type": "integer", "minimum": 1 },
    "branch_name": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "repository": { "type": "string" },
    "complexity": { "type": "string" },
    "status": { "type": "string" },
    "skipped_steps": { "type": "array", "items": { "type": "string" } },
    "feature_dir": { "type": "string" },
    "spec_file": { "type": "string" },
    "spec_path": { "type": "string" },
    "plan_file": { "type": "string" },
    "plan_path": { "type": "string" },
    "tasks_file": { "type": "string" },
    "tasks_path": { "type": "string" },
    "files_to_create": { "type": "array", "items": { "type": "string" } },
    "files_to_modify": { "type": "array", "items": { "type": "string" } },
    "files_to_delete": { "type": "array", "items": { "type": "string" } },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "file_changes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "action"],
              "properties": {
                "path": { "type": "string" },
                "action": { "type": "string", "enum": ["create", "modify", "delete"] }
              }
            }
          }
        }
      }
    },
    "summary": { "type": "string" }
  }
}
