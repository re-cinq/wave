{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Smoke Review Result",
  "type": "object",
  "required": ["success", "message"],
  "properties": {
    "success": {
      "type": "boolean",
      "description": "Whether the smoke review step completed successfully"
    },
    "message": {
      "type": "string",
      "description": "Explanation of the verification result"
    }
  },
  "additionalProperties": false
}
