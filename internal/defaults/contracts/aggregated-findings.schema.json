{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aggregated Findings Schema",
  "description": "Merged findings from multiple audit pipelines. Used as input to the rework gate for verdict synthesis.",
  "type": "object",
  "required": ["findings", "source_audits", "total_findings", "summary"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "severity", "source_audit"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Finding category from the source audit"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "source_audit": {
            "type": "string",
            "description": "Name of the audit pipeline that produced this finding"
          },
          "package": {
            "type": "string",
            "description": "Go package path (e.g., internal/bench)"
          },
          "file": {
            "type": "string",
            "description": "File path relative to project root"
          },
          "line": {
            "type": "integer",
            "description": "Line number if applicable"
          },
          "item": {
            "type": "string",
            "description": "Function, type, or item name"
          },
          "description": {
            "type": "string",
            "description": "Human-readable finding description"
          },
          "evidence": {
            "type": "string",
            "description": "Evidence supporting the finding"
          },
          "recommendation": {
            "type": "string",
            "description": "Suggested action",
            "enum": ["remove", "merge", "keep", "wire", "document", "investigate", "fix", "refactor"]
          }
        }
      }
    },
    "source_audits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "finding_count"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Audit pipeline name"
          },
          "finding_count": {
            "type": "integer",
            "description": "Number of findings from this audit"
          },
          "status": {
            "type": "string",
            "enum": ["completed", "failed", "skipped"],
            "description": "Whether the audit completed successfully"
          }
        }
      }
    },
    "total_findings": {
      "type": "integer",
      "description": "Total number of findings across all audits"
    },
    "summary": {
      "type": "string",
      "description": "One-line summary of aggregated results"
    },
    "aggregated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when aggregation completed"
    }
  },
  "additionalProperties": true
}
