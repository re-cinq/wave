{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewFeedback",
  "description": "Structured output of an agent review. Extracted from reviewer agent stdout.",
  "type": "object",
  "required": ["verdict", "issues", "suggestions", "confidence"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "warn"],
      "description": "Overall review verdict"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"],
            "description": "Issue severity level"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable description of the issue"
          }
        },
        "additionalProperties": false
      },
      "description": "List of issues found during review"
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Actionable improvement suggestions"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score for the review verdict (0.0 = no confidence, 1.0 = full confidence)"
    }
  },
  "additionalProperties": false
}
