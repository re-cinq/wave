{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiffSummary API Response",
  "description": "Response schema for GET /api/runs/{id}/diff — changed files summary for a pipeline run.",
  "type": "object",
  "required": ["files", "total_files", "total_additions", "total_deletions", "base_branch", "head_branch", "available"],
  "properties": {
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status", "additions", "deletions"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative file path within the repository"
          },
          "status": {
            "type": "string",
            "enum": ["added", "modified", "deleted", "renamed"],
            "description": "Change status"
          },
          "additions": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of lines added"
          },
          "deletions": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of lines deleted"
          },
          "binary": {
            "type": "boolean",
            "description": "Whether the file is binary"
          }
        },
        "additionalProperties": false
      }
    },
    "total_files": {
      "type": "integer",
      "minimum": 0
    },
    "total_additions": {
      "type": "integer",
      "minimum": 0
    },
    "total_deletions": {
      "type": "integer",
      "minimum": 0
    },
    "base_branch": {
      "type": "string"
    },
    "head_branch": {
      "type": "string"
    },
    "available": {
      "type": "boolean",
      "description": "Whether the diff is available (false when branch deleted or no branch)"
    },
    "message": {
      "type": "string",
      "description": "Human-readable status message when diff is unavailable"
    }
  },
  "additionalProperties": false
}
